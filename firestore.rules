rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Connection Test & Public Data
    match /test/{any=**} {
      allow read, write: if true;
    }

    match /schemes/{any=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /schemes {
      allow read: if true;
    }

    match /savedFiles/{fileId} {
      allow read, write: if true;
    }

    // 2. User Data (Owner only)
    // We use a recursive match for the entire user tree
    match /users/{userId}/{allData=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == userId);
    }
    
    // Also match the user document itself
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == userId);
    }

    // 3. Feedback
    match /feedbacks/{id} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }
    
    // Global Lock
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
