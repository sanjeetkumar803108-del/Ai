{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the user using the app",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "state": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "occupation": { "type": "string", "enum": ["Farmer", "Student", "Worker", "Unemployed", "Normal", "Naukri", "Other"] },
        "community": { "type": "string", "enum": ["Student", "Farmer", "Normal", "Jobs"] },
        "class": { "type": "string" },
        "stream": { "type": "string", "enum": ["PCB", "PCM", "Commerce", "Arts", "Others"] },
        "preferredLanguage": { "type": "string", "enum": ["hi", "en", "hinglish"] },
        "isPremium": { "type": "boolean" },
        "streak": { "type": "integer" },
        "lastLogin": { "type": "integer" },
        "hasCompletedTutorial": { "type": "boolean" },
        "savedSchemeIds": { "type": "array", "items": { "type": "string" } },
        "aadharNumber": { "type": "string" },
        "aadharDocUrl": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "address": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "monthlyIncome": { "type": "string" },
        "category": { "type": "string", "enum": ["General", "OBC", "SC", "ST", "EWS"] },
        "notificationsEnabled": { "type": "boolean" },
        "needs": { "type": "string" },
        "vaultPinSecured": { "type": "boolean" },
        "vaultPinCode": { "type": "string" },
        "vaultAccessLogs": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "preferredLanguage"]
    },
    "Conversation": {
      "title": "Chat Conversation",
      "description": "A conversation session containing multiple messages",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["userId", "title", "lastMessage", "updatedAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a chat session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "integer" }
      },
      "required": ["userId", "role", "content", "timestamp"]
    },
    "Application": {
      "title": "Scheme Application",
      "description": "Details of a user's government scheme application",
      "type": "object",
      "properties": {
        "schemeName": { "type": "string" },
        "applicationId": { "type": "string" },
        "status": { "type": "string", "enum": ["Submitted", "Under Review", "Approved", "Rejected"] },
        "updatedAt": { "type": "integer" },
        "notes": { "type": "string" }
      },
      "required": ["schemeName", "applicationId", "status", "updatedAt"]
    },
    "Feedback": {
      "title": "User Feedback",
      "description": "Feedback submitted by users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "type": { "type": "string", "enum": ["issue", "suggestion", "general", "scheme", "guide"] },
        "content": { "type": "string" },
        "rating": { "type": "integer" },
        "relatedId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] },
        "timestamp": { "type": "integer" }
      },
      "required": ["userId", "type", "content", "timestamp"]
    },
    "FormDraft": {
      "title": "Form Draft",
      "description": "A partially filled form draft",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "formName": { "type": "string" },
        "formData": { "type": "object" },
        "formDefinition": { "type": "object" },
        "updatedAt": { "type": "integer" },
        "isOfflineDraft": { "type": "boolean" }
      },
      "required": ["userId", "formName", "formData", "formDefinition", "updatedAt"]
    },
    "CachedScheme": {
      "title": "Cached AI Scheme",
      "description": "AI-generated scheme result cached for the user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "hindiName": { "type": "string" },
        "hindiDescription": { "type": "string" },
        "eligibility": { "type": "array", "items": { "type": "string" } },
        "benefits": { "type": "array", "items": { "type": "string" } },
        "documents": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "mitraId": { "type": "string" },
        "type": { "type": "string", "enum": ["ai"] },
        "cachedAt": { "type": "integer" }
      },
      "required": ["name", "description", "category", "cachedAt"]
    },
    "SavedFile": {
      "title": "Saved Document File",
      "description": "Document information with download/display payload",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "integer" },
        "fileType": { "type": "string" },
        "fileData": { "type": "string" },
        "createdAt": { "type": "integer" },
        "qrCodeUrl": { "type": "string" },
        "userId": { "type": "string" },
        "targetUrl": { "type": "string" },
        "ttl": { "type": "integer" },
        "notes": { "type": "string" }
      },
      "required": ["id", "fileName", "fileData", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/savedFiles/{fileId}": {
      "schema": "SavedFile",
      "description": "Saved files for QR scanning and verification"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Metadata for a chat conversation"
    },
    "/users/{userId}/conversations/{convId}/messages/{msgId}": {
      "schema": "ChatMessage",
      "description": "Individual messages within a conversation"
    },
    "/users/{userId}/applications/{appId}": {
      "schema": "Application",
      "description": "List of government scheme applications tracked by the user"
    },
    "/users/{userId}/drafts/{draftId}": {
      "schema": "FormDraft",
      "description": "User's partially filled form drafts"
    },
    "/users/{userId}/cachedSchemes/{id}": {
      "schema": "CachedScheme",
      "description": "AI-generated schemes cached for the user"
    },
    "/schemes/{schemeId}": {
      "schema": { "$ref": "CachedScheme" },
      "description": "Global government schemes data for all users"
    },
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Feedback from all users"
    }
  }
}
